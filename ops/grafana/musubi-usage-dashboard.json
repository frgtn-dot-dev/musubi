        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "delta(musubi_events_total{job=\"musubi-api\"}[24h])",
          "legendFormat": "net events / 24h"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "gradientMode": "none", "lineWidth": 1, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      }
    },
