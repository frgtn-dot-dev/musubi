        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      }
    },
