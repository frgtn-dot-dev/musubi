# Copy this file to `.env`, then replace every placeholder used by your
# deployment. Keep secrets out of Git and back them up outside the database.

# DB
POSTGRES_USER=musubi
POSTGRES_DB=musubi
# Replace this with a long random password.
POSTGRES_PASSWORD=change_for_random_long_password

# Local API/CLI connection. Docker Compose overrides the host to `db`.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Public API listener.
API_SERVER_PORT=7531

# API image tag (Docker Hub frgtndev/musubi, published on each release). Pin to
# a version so the API only updates when you bump it; `latest` = newest release.
MUSUBI_TAG=latest

# Internal Prometheus listener. Docker Compose does not publish this port to the
# host; set 0 to disable metrics entirely.
METRICS_PORT=9464

# `dev` enables destructive/reset and permissive development behavior. Use a
# non-dev value in production.
ENVIRONMENT=dev

# Server log verbosity: debug, info, warn, error, or silent. Defaults to info.
# Use debug temporarily when diagnosing provider/calendar synchronization.
LOG_LEVEL=info

# BETTER_AUTH_URL must be ORIGIN ONLY — no "/api" suffix.
# The client (services/api.ts) and Better Auth both append "/api/..." themselves.
# Wrong:   https://musubi.pro/api  → produces /api/api/... → 404
# Right:   https://musubi.pro
BETTER_AUTH_URL=http://localhost:7531
# Generate with: openssl rand -base64 32   (keep it private and stable — changing
# it logs everyone out and orphans encrypted OAuth tokens)
BETTER_AUTH_SECRET=your_secret_here

# --- Everything below is OPTIONAL: the API boots without it. ---

# SMTP — password-reset and other transactional emails. Leave blank to skip.
SMTP_HOST=smtp.sendlayer.net
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
FROM_EMAIL=sender@example.com

# Google OAuth — required only for Google sign-in and Google Calendar sync.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=

# Client-side, baked into the mobile app at BUILD time — the server ignores
# these, so a server self-host can leave them blank. The web id is the idToken
# audience for both platforms; the iOS id is the native Google SDK client and is
# REQUIRED for Google sign-in on iOS (its reversed form becomes the URL scheme).
# Create an "iOS" OAuth client for bundle dev.frgtn.musubi in Google Cloud.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Microsoft OAuth (Entra ID app registration) — required only for Outlook
# calendar sync. Redirect URI on the portal: {BETTER_AUTH_URL}/api/auth/callback/microsoft
# Tenant defaults to "common" (any Microsoft account incl. personal); set a
# tenant id only when restricting to a single organization.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
#MICROSOFT_TENANT_ID=common

# Sign in with Apple (native, iOS only) — set to your app's bundle id
# (dev.frgtn.musubi). Presence flips the "Continue with Apple" button on; the
# server verifies the identity token's audience against the app bundle id.
APPLE_CLIENT_ID=

# Apple Developer Team ID (10 chars, Apple Developer → Membership). Enables the
# apple-app-site-association file (served at /.well-known/) so iOS invite links
# open the app directly. Unset → that endpoint 404s (universal links just don't
# engage; the Safari hand-off page still works).
APPLE_TEAM_ID=

# Encrypts stored secrets: CalDAV passwords and federated Musubi member tokens.
# Required before anyone connects a CalDAV account (iCloud/Fastmail/…) or a
# federated connection is stored. Generate with: openssl rand -hex 32
CALDAV_ENC_KEY=

# Minutes between scheduled external-provider syncs
# (Google/Microsoft/CalDAV polling → SSE updates). Defaults to 5; 0 disables.
EXTERNAL_SYNC_INTERVAL_MIN=5
